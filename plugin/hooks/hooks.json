{
  "description": "Impeccable design detector: runs after Write/Edit/MultiEdit on UI files and surfaces findings as system reminders.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/skills/impeccable/scripts/hook.mjs"
            ],
            "if": "Edit(*.{tsx,jsx,html,vue,svelte,astro,css,scss,less,ts,js})",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/skills/impeccable/scripts/hook-session-start.mjs"
            ],
            "timeout": 3
          }
        ]
      }
    ]
  }
}
