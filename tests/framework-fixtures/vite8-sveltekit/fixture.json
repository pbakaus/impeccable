{
  "name": "Vite 8 + SvelteKit 2 + Svelte 5",
  "config": {
    "files": ["src/app.html"],
    "insertBefore": "</body>",
    "commentSyntax": "html"
  },
  "sourceFiles": ["src/app.html", "src/routes/+page.svelte", "src/routes/+layout.svelte", "svelte.config.js", "vite.config.js"],
  "generatedFiles": [],
  "wrapCases": [
    {
      "name": "wraps hero title in route source",
      "args": { "classes": "hero-title", "tag": "h1" },
      "expectedFile": "src/routes/+page.svelte"
    }
  ],
  "runtime": {
    "styling": "plain-css",
    "install": ["npm", "install", "--no-audit", "--no-fund", "--loglevel=error"],
    "devCommand": ["npx", "vite", "dev", "--host", "127.0.0.1"],
    "readyPattern": "Local:\\s+https?://[^:]+:(\\d+)",
    "readyTimeoutMs": 120000,
    "probe": {
      "expectLiveInit": true,
      "expectConsoleClean": true
    },
    "manualEditScenarios": [
      {
        "name": "Svelte Edit Save Apply batch then Go Accept",
        "element": { "selector": "section.hero-copy", "position": { "x": 4, "y": 4 } },
        "edits": [
          {
            "leafSelector": "h1.hero-title",
            "originalText": "Vite 8 + SvelteKit Fixture",
            "newText": "SvelteKit Batch Title Applied",
            "expectedSourceFile": "src/routes/+page.svelte"
          },
          {
            "leafSelector": "p.hero-hook",
            "originalText": "Minimal SvelteKit route for live-mode E2E tests.",
            "newText": "SvelteKit batch hook applied through manual edit.",
            "expectedSourceFile": "src/routes/+page.svelte"
          }
        ],
        "expectedStashCount": 2,
        "afterApply": [{ "type": "variantAccept", "selector": "h1.hero-title" }]
      },
      {
        "name": "Svelte Go Accept then Edit Save Apply hook",
        "beforeManualEdit": [{ "type": "variantAccept", "selector": "h1.hero-title" }],
        "element": { "selector": "section.hero-copy", "position": { "x": 4, "y": 4 } },
        "edits": [
          {
            "leafSelector": "p.hero-hook",
            "originalText": "Minimal SvelteKit route for live-mode E2E tests.",
            "newText": "Svelte hook changed after Go accept.",
            "expectedSourceFile": "src/routes/+page.svelte"
          }
        ],
        "expectedStashCount": 1
      },
      {
        "name": "Svelte Edit Save then Go Accept then Apply commit",
        "element": { "selector": "section.hero-copy", "position": { "x": 4, "y": 4 } },
        "edits": [
          {
            "leafSelector": "h1.hero-title",
            "originalText": "Vite 8 + SvelteKit Fixture",
            "newText": "Svelte title committed after Go.",
            "expectedSourceFile": "src/routes/+page.svelte"
          }
        ],
        "afterSave": [{ "type": "acceptCurrentSelection" }],
        "expectedStashCount": 1,
        "afterApply": [{ "type": "variantAccept", "selector": "h1.hero-title" }]
      },
      {
        "name": "Svelte expression count edit keeps typed model",
        "element": { "selector": "section.capacity-panel", "position": { "x": 4, "y": 4 } },
        "edits": [
          {
            "leafSelector": "span.capacity-count",
            "originalText": "7",
            "newText": "7 Svelte seats",
            "expectedSourceFile": "src/routes/+page.svelte",
            "expectedSourceMatch": "<span class=\"capacity-count\">{\"7 Svelte seats\"}</span>",
            "expectedSourceAlso": [
              "const stats = { seats: 7 };",
              "assertIntegerStat(stats.seats)"
            ],
            "expectedVisibleText": "7 Svelte seats"
          }
        ],
        "expectedStashCount": 1
      }
    ]
  }
}
