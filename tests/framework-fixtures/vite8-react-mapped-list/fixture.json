{
  "name": "Vite 8 + React + .map() instances (3 cards from one template)",
  "config": {
    "files": ["index.html"],
    "insertBefore": "</body>",
    "commentSyntax": "html"
  },
  "sourceFiles": ["index.html", "src/App.jsx", "src/main.jsx", "src/styles.css", "vite.config.js"],
  "generatedFiles": [],
  "wrapCases": [
    {
      "name": "wraps the mapped h1 template in source JSX",
      "args": { "classes": "hero-title", "tag": "h1" },
      "expectedFile": "src/App.jsx"
    }
  ],
  "runtime": {
    "styling": "plain-css",
    "install": ["npm", "install", "--no-audit", "--no-fund", "--loglevel=error"],
    "devCommand": ["npx", "vite", "--host", "127.0.0.1"],
    "readyPattern": "Local:\\s+https?://[^:]+:(\\d+)",
    "readyTimeoutMs": 120000,
    "probe": {
      "expectLiveInit": true,
      "expectConsoleClean": true
    },
    "manualEditScenarios": [
      {
        "name": "Edit first Save then Go Accept second then Apply first, then Edit third Save Apply",
        "stages": [
          {
            "element": { "selector": "article.card:nth-of-type(1) h1.hero-title" },
            "edits": [
              {
                "leafSelector": "article.card:nth-of-type(1) h1.hero-title",
                "originalText": "Alpha card",
                "newText": "Alpha card manually applied",
                "expectedSourceFile": "src/App.jsx"
              }
            ],
            "expectedStashCount": 1,
            "afterSave": [{ "type": "variantAccept", "selector": "article.card:nth-of-type(2) h1.hero-title" }]
          },
          {
            "element": { "selector": "article.card:nth-of-type(3) h1.hero-title" },
            "edits": [
              {
                "leafSelector": "article.card:nth-of-type(3) h1.hero-title",
                "originalText": "Gamma card",
                "newText": "Gamma card manually applied",
                "expectedSourceFile": "src/App.jsx"
              }
            ],
            "expectedStashCount": 1
          }
        ]
      },
      {
        "name": "Go Accept first then Edit Save Apply second",
        "beforeManualEdit": [{ "type": "variantAccept", "selector": "article.card:nth-of-type(1) h1.hero-title" }],
        "element": { "selector": "article.card:nth-of-type(2)" },
        "edits": [
          {
            "leafSelector": "article.card:nth-of-type(2) h1.hero-title",
            "originalText": "Beta card",
            "newText": "Beta card edited after Go accept",
            "expectedSourceFile": "src/App.jsx"
          }
        ],
        "expectedStashCount": 1
      },
      {
        "name": "Edit all mapped titles and bodies in one Apply then Go Accept",
        "element": { "selector": "main.page", "position": { "x": 4, "y": 4 } },
        "edits": [
          {
            "leafSelector": "article.card:nth-of-type(1) h1.hero-title",
            "originalText": "Alpha card",
            "newText": "Alpha launch slot",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Alpha launch slot"
          },
          {
            "leafSelector": "article.card:nth-of-type(1) p.card-body",
            "originalText": "Alpha detail",
            "newText": "Alpha copy applied",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Alpha copy applied"
          },
          {
            "leafSelector": "article.card:nth-of-type(2) h1.hero-title",
            "originalText": "Beta card",
            "newText": "Beta launch slot",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Beta launch slot"
          },
          {
            "leafSelector": "article.card:nth-of-type(2) p.card-body",
            "originalText": "Beta detail",
            "newText": "Beta copy applied",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Beta copy applied"
          },
          {
            "leafSelector": "article.card:nth-of-type(3) h1.hero-title",
            "originalText": "Gamma card",
            "newText": "Gamma launch slot",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Gamma launch slot"
          },
          {
            "leafSelector": "article.card:nth-of-type(3) p.card-body",
            "originalText": "Gamma detail",
            "newText": "Gamma copy applied",
            "expectedSourceFile": "src/App.jsx",
            "expectedVisibleText": "Gamma copy applied"
          }
        ],
        "expectedStashCount": 6,
        "afterApply": [{ "type": "variantAccept", "selector": "article.card:nth-of-type(2) h1.hero-title" }]
      }
    ]
  }
}
