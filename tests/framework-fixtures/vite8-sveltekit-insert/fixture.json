{
  "name": "Vite 8 + SvelteKit insert mode E2E",
  "config": {
    "files": ["src/app.html"],
    "insertBefore": "</body>",
    "commentSyntax": "html"
  },
  "sourceFiles": ["DESIGN.md", "src/app.html", "src/routes/+page.svelte", "src/routes/+layout.svelte", "svelte.config.js", "vite.config.js"],
  "generatedFiles": [],
  "wrapCases": [],
  "runtime": {
    "mode": "insert",
    "styling": "plain-css",
    "install": ["npm", "install", "--no-audit", "--no-fund", "--loglevel=error"],
    "devCommand": ["npx", "vite", "dev", "--host", "127.0.0.1"],
    "readyPattern": "Local:\\s+https?://[^:]+:(\\d+)",
    "readyTimeoutMs": 120000,
    "steer": false,
    "variantSequence": [2, 3, 2, 3],
    "insert": {
      "anchorSelector": ".empty-card",
      "position": "after",
      "prompt": "Insert a concise muted footnote below the empty expenses card explaining that shared expenses sync automatically.",
      "expectSelector": ".inserted-strip",
      "expectSelectorLlm": ".empty-card + *",
      "expectSourcePattern": "automatisch|synchron|sync|abgeglichen|shared expenses",
      "assertAnchorContains": "empty-card"
    },
    "probe": {
      "expectLiveInit": true,
      "expectConsoleClean": true
    },
    "assertSourceContains": [
      "Offene Ausgaben",
      "empty-card"
    ]
  }
}
